---
// @ts-nocheck
import { getCollection } from 'astro:content';
const cmsMode = import.meta.env.KEYSTATIC_MODE ?? (import.meta.env.PROD ? 'disabled' : 'local');
var projects = [];
var articles = [];
var publicProjects = [];
var publicArticles = [];
var drafts = 0;
var featured = [];
if (cmsMode === 'disabled') {
  // Production keeps the public surface closed until GitHub mode is configured.
} else {
  projects = await getCollection('projects');
  articles = await getCollection('articles');
  var publicProjects = projects.filter(({ data }) => !data.draft);
  var publicArticles = articles.filter(({ data }) => !data.draft);
  var drafts = [...projects, ...articles].filter(({ data }) => data.draft).length;
  var featured = [...projects, ...articles].filter(({ data }) => data.featured).slice(0, 5);
}
---
{cmsMode === 'disabled' ? <html lang="zh-CN"><head><meta charset="utf-8" /><meta name="robots" content="noindex,nofollow" /><title>后台尚未启用</title></head><body><main class="admin-disabled"><h1>后台尚未启用</h1><p>当前生产构建未启用正式 CMS 后台。</p></main></body></html> : <html lang="zh-CN"><head><meta charset="utf-8" /><meta name="viewport" content="width=device-width" /><meta name="robots" content="noindex,nofollow" /><title>Website Studio</title></head><body class="admin-body"><main class="admin-shell"><header class="admin-topbar"><div><p class="admin-kicker">Website Studio</p><h1>网站工作台</h1><p>从这里进入编辑、预览和媒体检查。保存仍由编辑后台完成。</p></div><a class="admin-link admin-link--primary" href="/keystatic">打开编辑后台</a></header><section class="admin-stats" aria-label="网站概况"><div><strong>{publicProjects.length}</strong><span>已发布项目</span></div><div><strong>{drafts}</strong><span>待处理草稿</span></div><div><strong>{publicArticles.length}</strong><span>已发布文章</span></div><div><strong>{[...projects, ...articles].filter(({ data }) => data.coverImage || data.socialImage).length}</strong><span>已引用媒体</span></div></section><section class="admin-shortcuts"><h2>快速开始</h2><div class="admin-actions"><a href="/keystatic/collection/projects">新建项目</a><a href="/keystatic/collection/articles">新建文章</a><a href="/keystatic/singleton/homepage">编辑首页</a><a href="/keystatic/singleton/profile">编辑关于我</a><a href="/keystatic/singleton/siteSettings">网站设置</a><a href="/admin/media">媒体库</a><a href="/admin/preview">打开前台预览</a></div></section><section class="admin-notices"><h2>需要留意</h2><ul><li class:list={{ 'admin-notice--ok': drafts === 0 }}>{drafts > 0 ? `当前有 ${drafts} 项草稿，发布前请逐项检查。` : '暂无草稿。'}</li><li>图片上传限制：jpg、jpeg、png、webp，单文件不超过 2MB。</li><li>SEO、Alt、链接和图片检查在构建时执行。</li><li>当前是 local mode；正式 GitHub mode 尚未启用。</li></ul></section><section class="admin-recent"><h2>最近内容</h2>{featured.length === 0 ? <p>暂无推荐内容，新增或编辑内容后会显示在这里。</p> : <ul>{featured.map(({ data }) => <li><span>{data.title}</span><span>{data.publicationStatus === 'archived' ? '已归档' : data.draft ? '草稿' : '已发布'}</span></li>)}</ul>}</section></main></body></html>}
