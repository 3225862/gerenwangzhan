---
import LanguageSwitcher from './LanguageSwitcher.astro';
import PageContainer from './PageContainer.astro';
import { getSiteData } from '../lib/site-data.js';
const site = await getSiteData();
---
<footer class="site-footer">
  <PageContainer>
    <div class="site-footer__inner">
      <div class="site-footer__top">
        <div>
          <div class="site-footer__brand">{site.siteName}</div>
          <p class="site-footer__description">{site.description}</p>
        </div>
        <div class="site-footer__links">
          {site.footerLinks.map((link) => <a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}>{link.label}</a>)}
        </div>
      </div>
      <div class="site-footer__bottom"><span>© {new Date().getFullYear()} {site.siteName}</span><LanguageSwitcher /></div>
    </div>
  </PageContainer>
</footer>
