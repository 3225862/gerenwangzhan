---
// @ts-nocheck
import { getCollection } from 'astro:content'; import ContentContainer from '../components/ContentContainer.astro'; import Section from '../components/Section.astro'; import SectionHeader from '../components/SectionHeader.astro'; import SiteLayout from '../layouts/SiteLayout.astro'; import { publicEntries, sortEntries, paragraphs } from '../lib/extended-models.js';
const timeline = sortEntries(publicEntries(await getCollection('timeline'))); const experiences = sortEntries(publicEntries(await getCollection('experiences'))); const education = sortEntries(publicEntries(await getCollection('education'))); const date = (item) => item.data.startDate ? item.data.startDate.toLocaleDateString('zh-CN') : '';
---
<SiteLayout title="经历与时间轴" description="经历、教育与时间轴记录。"><Section><ContentContainer><SectionHeader eyebrow="时间轴" title="经历与教育" description="按时间整理的公开记录。" />{timeline.length + experiences.length + education.length === 0 ? <div class="empty-state">暂无已发布记录。</div> : <div class="timeline-list">{[...experiences.map((item) => ({ ...item, kind: '经历' })), ...education.map((item) => ({ ...item, kind: '教育' })), ...timeline.map((item) => ({ ...item, kind: item.data.kind || '时间点' }))].map((item) => <article class="timeline-item"><div class="timeline-item__marker" aria-hidden="true"></div><div><div class="caption">{item.kind} {date(item)}</div><h2>{item.data.title}</h2><p>{item.data.summary}</p>{item.data.body && paragraphs(item.data.body).map((text) => <p>{text}</p>)}</div></article>)}</div>}</ContentContainer></Section></SiteLayout>
