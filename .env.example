# Local development defaults to Local Mode. Production defaults to GitHub Mode.
KEYSTATIC_MODE=local

# Required for production GitHub Mode. Never commit real values.
KEYSTATIC_GITHUB_REPO=owner/private-repository
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=

# The branch is controlled by the GitHub repository/default branch.
KEYSTATIC_GITHUB_BRANCH=main
PUBLIC_SITE_URL=http://localhost:4321
