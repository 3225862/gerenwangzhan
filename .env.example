# P0 local mode uses no secret and writes content to the repository.
# Set SKIP_KEYSTATIC=true only for a production build that must omit CMS routes.
SKIP_KEYSTATIC=false

# Reserved for P9 GitHub mode. Never put real values in this file.
# KEYSTATIC_GITHUB_REPO=owner/private-repository
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
