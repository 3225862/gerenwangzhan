{
  "name": "personal-site",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "check": "node scripts/check.mjs",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "check:content": "node scripts/validate-content.mjs",
    "check:external": "node scripts/check-external-dependencies.mjs",
    "check:p2-build": "node scripts/check-p2-build.mjs",
    "check:links": "node scripts/check-links.mjs"
  },
  "dependencies": {
    "@astrojs/markdoc": "2.0.3",
    "@astrojs/react": "6.0.1",
    "@astrojs/vercel": "11.0.3",
    "@keystatic/astro": "5.2.0",
    "@keystatic/core": "0.5.51",
    "astro": "7.0.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
